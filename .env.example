# Copy to .env and fill in. Never commit .env.

# Supabase (from `supabase start` or dashboard)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Claude (Anthropic) — orchestrator, semantic diff, evidence memos
ANTHROPIC_API_KEY=
# Model name (e.g. claude-sonnet-4-20250514, claude-3-5-sonnet-20241022)
CLAUDE_MODEL=

# Browser-Use (browser automation)
BROWSER_USE_API_KEY=

# Linear (tickets)
LINEAR_API_KEY=

# Slack (notifications)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Optional: Redis (caching / queue)
REDIS_URL=redis://localhost:6379

# Evidence storage: use Supabase Storage when true
USE_SUPABASE_STORAGE=true

# Optional: AWS S3 (if USE_SUPABASE_STORAGE=false)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_EVIDENCE_BUCKET=compliance-radar-evidence

# Evidence signing (HMAC) — generate a random secret
EVIDENCE_SIGNING_KEY=

# Frontend (Next.js) — same Supabase keys, with NEXT_PUBLIC_ prefix for client
# NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_API_URL=http://localhost:8000
